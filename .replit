modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["gitFull", "playwright-driver"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "run:app"]

[userenv]

[userenv.shared]
FLASK_HOST = "0.0.0.0"
FLASK_PORT = "5000"
FLASK_DEBUG = "true"
MONGODB_DB_NAME = "job_orchestrator"
PLAYWRIGHT_HEADLESS = "true"
PLAYWRIGHT_START_MAXIMIZED = "true"
PLAYWRIGHT_NO_VIEWPORT = "true"
SCHEDULER_ENABLED = "true"
SCHEDULER_TIMEZONE = "Indian/Antananarivo"
SCHEDULER_TARGET_HOUR_MADA = "16"
SCHEDULER_TARGET_MINUTE_MADA = "0"
CORS_ALLOWED_ORIGINS = "http://localhost:5173,http://127.0.0.1:5173,https://job-application-orchestrator-ui.vercel.app"
