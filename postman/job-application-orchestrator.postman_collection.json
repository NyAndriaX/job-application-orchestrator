{
  "info": {
    "_postman_id": "f6d4fa0a-6c20-4d73-9e18-0bf5a9d6e311",
    "name": "Job Application Orchestrator API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing auth, profile V2 filters (skills/scoring), platform config, and orchestration."
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Auth - Register (V2 Profile Fields)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.user && json.user.user_id) {",
              "    pm.collectionVariables.set('user_id', json.user.user_id);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"Jean User\",\n  \"email\": \"jean@example.com\",\n  \"password\": \"Password123\",\n  \"filters\": [\"cdi\", \"stage\"],\n  \"skills\": [\"python\", \"backend\", \"api\", \"flask\"],\n  \"excluded_keywords\": [\"televente\", \"comptable\", \"rh\"],\n  \"min_relevance_score\": 3,\n  \"max_jobs\": 10\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jean@example.com\",\n  \"password\": \"Password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Users - Update Profile (V2 Filters + Scoring)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"filters\": [\"cdi\"],\n  \"skills\": [\"python\", \"backend\", \"api\", \"flask\", \"automation\"],\n  \"excluded_keywords\": [\"televente\", \"commercial\", \"comptable\"],\n  \"min_relevance_score\": 3,\n  \"max_jobs\": 10\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "profile"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Users - Save Platform Config (Asako)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"platform\": \"asako\",\n  \"auth\": {\n    \"email\": \"jean@example.com\",\n    \"password\": \"Password123\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/platform-config",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "platform-config"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Orchestrate - Asako (Uses Saved Profile V2)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"platform\": \"asako\",\n  \"mode\": \"auto_apply\",\n  \"user_id\": \"{{user_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/orchestrate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "orchestrate"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Scheduler - Run Now (All Users Auto Apply)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{base_url}}/scheduler/run-now",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "scheduler",
            "run-now"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "user_id",
      "value": ""
    }
  ]
}
