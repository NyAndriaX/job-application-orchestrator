    {
      "name": "Auth - Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.user && json.user.user_id) {",
              "    pm.collectionVariables.set('user_id', json.user.user_id);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"Jean User\",\n  \"email\": \"jean@example.com\",\n  \"password\": \"Password123\",\n  \"filters\": [\"cdi\", \"stage\"]\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
